# Copy this file to .env and replace every value before running Docker Compose.
# Tokens must contain at least 16 characters. Separate tenant credentials with ';'.
REDIS_PASSWORD=replace-with-a-long-random-redis-password
ADMIN_API_KEY=replace-with-a-long-random-admin-token
TENANT_API_KEYS=tenant-a=replace-with-a-long-tenant-a-token;premium-tenant=replace-with-a-long-premium-token
